# ============================================================
# 工业温控时序监控系统 - 环境配置
# 复制为 .env 后修改，docker compose 会自动加载
# ============================================================

# 端口映射
INFLUXDB_PORT=8086
GRAFANA_PORT=3000
MQTT_PORT=1883
MQTT_WS_PORT=9001

# 认证凭据（首次部署后请修改密码！）
INFLUXDB_USER=admin
INFLUXDB_PASSWORD=admin123
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
GRAFANA_ANONYMOUS=true

# 时区
TZ=Asia/Shanghai